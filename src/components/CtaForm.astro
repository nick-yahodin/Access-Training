---
import Button from "./Button.astro";

interface Props {
  variant?: "dark" | "light";
}
const { variant = "dark" }: Props = Astro.props;
const isDark = variant === "dark";
const bg = isDark ? "bg-brand-primary" : "bg-brand-cream";
const text = isDark ? "text-neutral-0" : "text-brand-primary";
const inputBg = isDark
  ? "bg-brand-primary-700 border-brand-primary-500 text-neutral-0 placeholder:text-neutral-400"
  : "bg-neutral-0 border-neutral-200 text-brand-primary placeholder:text-neutral-400";
---

<section class={`${bg} ${text}`}>
  <div class="container-page py-14 md:py-20 grid gap-8 md:grid-cols-[1fr_1.5fr] items-center">
    <div class="space-y-3">
      <h2 class="display text-4xl md:text-5xl">
        Start your <span class="text-brand-warning">journey.</span><br />
        Get in <span class="text-brand-accent">touch.</span>
      </h2>
    </div>

    <form class="space-y-4">
      <div class="grid gap-3 md:grid-cols-3">
        <input
          type="text"
          name="firstName"
          placeholder="First name"
          class={`px-4 py-3 rounded-full border ${inputBg} text-sm outline-none focus:border-brand-accent transition-colors`}
        />
        <input
          type="email"
          name="email"
          placeholder="Email address"
          class={`px-4 py-3 rounded-full border ${inputBg} text-sm outline-none focus:border-brand-accent transition-colors`}
        />
        <input
          type="tel"
          name="phone"
          placeholder="Phone number"
          class={`px-4 py-3 rounded-full border ${inputBg} text-sm outline-none focus:border-brand-accent transition-colors`}
        />
      </div>
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <label class="flex items-start gap-2 text-xs text-neutral-400">
          <input type="checkbox" class="mt-0.5" />
          <span>
            I agree to receive updates, offers and course information.
          </span>
        </label>
        <Button type="submit" variant="accent" size="lg">Enquire Now</Button>
      </div>
    </form>
  </div>
</section>
