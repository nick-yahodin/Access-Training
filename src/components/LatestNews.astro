---
const posts = [
  {
    title: "Training centres in Wales: train locally, qualify nationally",
    date: "April 12, 2026",
    read: "3 minute read",
    img: "/images/news-wales.png",
    href: "/blog/wales",
  },
  {
    title: "Plumbing while you earn: how the system really works",
    date: "April 12, 2026",
    read: "4 minute read",
    img: "/images/news-plumbing.png",
    href: "/blog/earn-plumbing",
  },
  {
    title: "Train in the UK Midlands: central training hubs",
    date: "April 12, 2026",
    read: "2 minute read",
    img: "/images/news-midlands.png",
    href: "/blog/midlands",
  },
  {
    title: "Start your trade career in Scotland with real opportunities",
    date: "April 12, 2026",
    read: "4 minute read",
    img: "/images/news-scotland.png",
    href: "/blog/scotland",
  },
];
---

<section class="bg-black text-white py-20">
  <div class="container-page space-y-12">
    <div class="text-center space-y-5">
      <h2 class="display text-5xl md:text-7xl lg:text-[96px] leading-[1.05]">
        Latest <span class="text-[#ffbe00]">news</span>
      </h2>
      <p class="text-lg text-neutral-300 max-w-2xl mx-auto">
        Learn all about the training courses we provide and catch up on recent
        news stories from the trade world.
      </p>
      <div class="flex justify-center pt-2">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/30 hover:border-white hover:bg-white/5 transition-colors"
        >
          View All <span aria-hidden>↗</span>
        </a>
      </div>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {posts.map((p) => (
        <article class="space-y-4">
          <a href={p.href} class="block aspect-[5/4] rounded-2xl overflow-hidden">
            <img src={p.img} alt={p.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </a>
          <div class="space-y-2 px-1">
            <a href={p.href} class="block text-lg leading-snug hover:text-[#ffbe00]">{p.title}</a>
            <p class="text-xs text-neutral-400">{p.date} | {p.read}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
