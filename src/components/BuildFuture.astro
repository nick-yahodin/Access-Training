---
const steps = [
  {
    n: "01",
    label: "Live online theory",
    title: "Start training online",
    body: "Complete the first part of your training from home with Access Training Online and live tutor support.",
    body2: "Join live and recorded classes, interactive tests, tutor Q&As, and additional learning materials.",
  },
  {
    n: "02",
    label: "Practical training",
    title: "Learn by doing",
    body: "Once you've built a strong foundation, you'll attend one of our fully equipped training centres for hands-on practice.",
    body2: "Enjoy flexible hands-on learning, expert tutor support, and industry-recognised assessments.",
  },
  {
    n: "03",
    label: "Career & Recruitment",
    title: "Help getting into the industry",
    body: "As you near the end of your course, our Career Support team will help you plan and achieve your career goals.",
    body2: "Get expert advice, CV support, exclusive job opportunities, and guidance on starting your own business.",
  },
];

const reviews = [
  {
    title: "Access Training Sheffield",
    body: "Recently had my 2 week practical training with Access Training in Sheffield. I had Callum as my practical training instructor, he was very friendly and patient.",
    name: "Luke Anderson, 15 April 2026",
  },
  {
    title: "Great service felt very supported",
    body: "I just finished my practical assignment. I had Callum as my practical trainer. He was great tutor providing key information supported me in all aspects.",
    name: "Mr Karmjit Singh, 15 April 2026",
  },
  {
    title: "I'm doing domestic gas and until know…",
    body: "I'm doing domestic gas and until know is been great. There's a lot of support throughout the course and the tutors been great. I've learned…",
    name: "Bruno d' Barros, 24 April 2026",
  },
];
---

<section class="bg-[#ECEBE6] text-black py-20">
  <div class="container-page space-y-16">
    <div class="text-center space-y-4 max-w-3xl mx-auto">
      <h2 class="display text-5xl md:text-7xl lg:text-[96px] leading-[1.05]">
        Build your <br />
        <span class="text-[#2e9494]">future in 3 steps</span>
      </h2>
      <p class="text-lg text-neutral-700">
        Flexible training and career support designed to help you build
        practical skills and move into a new profession.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1fr_1fr] items-start">
      <ol class="space-y-3">
        {steps.map((s, i) => (
          <li class="rounded-2xl bg-white p-6">
            <div class="flex items-start gap-4">
              <span class="display text-2xl text-[#2e9494] shrink-0">{s.n}</span>
              <div class="space-y-2 flex-1">
                <p class="text-lg font-medium">{s.label}</p>
                {i === 0 && (
                  <div class="space-y-3 pt-2 border-t border-neutral-200">
                    <p class="text-3xl font-medium pt-3">{s.title}</p>
                    <p class="text-sm text-neutral-600">{s.body}</p>
                    <p class="text-sm text-neutral-600">{s.body2}</p>
                  </div>
                )}
              </div>
            </div>
          </li>
        ))}
      </ol>

      <div class="rounded-2xl overflow-hidden bg-white">
        <div class="aspect-[5/4]">
          <img
            src="/images/hero-portrait.png"
            alt="Student in training"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>

    <div class="rounded-2xl bg-white p-6 md:p-10 max-w-4xl mx-auto space-y-5">
      <h3 class="text-2xl font-medium">Help getting into the industry</h3>
      <ul class="space-y-3 text-neutral-700">
        <li class="flex gap-3">
          <span class="text-[#2e9494] shrink-0">→</span>
          <span>As you near the end of your course, our Career Support team will help you plan and achieve your career goals.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[#2e9494] shrink-0">→</span>
          <span>Get expert advice, CV support, exclusive job opportunities, and guidance on starting your own business.</span>
        </li>
      </ul>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {reviews.map((r) => (
        <article class="space-y-3">
          <h4 class="text-xl font-medium">{r.title}</h4>
          <p class="text-sm text-neutral-600 leading-relaxed">{r.body}</p>
          <div class="flex items-center gap-1 text-[#2e9494] pt-1 text-sm">
            ★★★★★ <span class="text-xs text-neutral-500 ml-2">{r.name}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
