---
const trades = [
  {
    title: "Plumbing",
    desc: "Plumber training courses are designed to get you qualified faster than a traditional further education college, helping you start your new career.",
    img: "/images/trade-plumbing.png",
    chip: "🛠",
    chipColor: "bg-[#1c98d5]",
    href: "/courses/plumbing",
  },
  {
    title: "Gas Engineer",
    desc: "Accredited gas courses across the UK for all levels with hands-on training. We offer gas safety courses at all levels, with no gas safety experience.",
    img: "/images/trade-gas.png",
    chip: "🔥",
    chipColor: "bg-[#ee7d5c]",
    href: "/courses/gas",
  },
  {
    title: "Electrician",
    desc: "Our comprehensive electrical training courses are suitable for adult learners of all ages and backgrounds. We've trained 100,000+ students!",
    img: "/images/trade-electrician.png",
    chip: "⚡",
    chipColor: "bg-[#ffbe00]",
    href: "/courses/electrician",
  },
  {
    title: "Unsure where to start?",
    desc: "Take this quick quiz and we'll help you find the right training program to match your goals, experience, and future career path.",
    img: "/images/trade-unsure.png",
    chip: "?",
    chipColor: "bg-[#2e9494]",
    href: "/quiz",
    cta: "Take Our Mini-Quiz Here",
  },
];
---

<section class="bg-black text-white py-20">
  <div class="container-page space-y-12">
    <div class="text-center space-y-4 max-w-3xl mx-auto">
      <h2 class="display text-5xl md:text-7xl lg:text-[96px] leading-[1.05]">
        Our trades <br />
        <span class="text-[#ffbe00]">and courses</span>
      </h2>
      <p class="text-lg text-neutral-300">
        Build a secure, rewarding career with greater autonomy and take control
        of your future with the support of expert tutors.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {trades.map((t) => (
        <article class="rounded-2xl overflow-hidden bg-[#0e0e0e] border border-white/5 flex flex-col md:flex-row">
          <div class="md:w-2/5 aspect-[4/3] md:aspect-auto md:min-h-[280px] overflow-hidden">
            <img src={t.img} alt={t.title} class="w-full h-full object-cover" />
          </div>
          <div class="p-6 space-y-3 flex-1 flex flex-col">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-2xl font-medium">{t.title}</h3>
              <span class={`w-9 h-9 rounded-full ${t.chipColor} text-white grid place-items-center text-lg shrink-0`}>{t.chip}</span>
            </div>
            <p class="text-sm text-neutral-400 flex-1">{t.desc}</p>
            <a
              href={t.href}
              class="inline-flex items-center gap-1 text-sm font-medium text-white hover:text-[#2e9494] pt-2"
            >
              {t.cta || "View Courses"} <span aria-hidden>↗</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="flex justify-center pt-6">
      <a
        href="/courses"
        class="inline-flex items-center gap-2 px-7 py-4 rounded-full border border-white/30 text-base font-medium hover:border-white hover:bg-white/5 transition-colors"
      >
        View All Available Courses <span aria-hidden>↗</span>
      </a>
    </div>
  </div>
</section>
