---
const cards = [
  {
    title: "Partners",
    desc: "Priority access to our network of affiliates and commercial partners, giving you more opportunities and connections within the industry.",
    chip: "+150 more",
    visual: "partners",
  },
  {
    title: "Get career support",
    desc: "Continuous professional development, including help with getting self-employed, CV writing and 3 years of guaranteed career support.",
    chip: "✓✓✓",
    visual: "support",
  },
  {
    title: "Exclusive jobs",
    desc: "Exclusive job opportunities and career prospects to help you progress in your chosen trade and secure the right roles.",
    chip: "🔍",
    visual: "jobs",
  },
];
---

<section class="bg-[#ECEBE6] text-black pb-20">
  <div class="container-page space-y-10">
    <h2 class="display text-4xl md:text-6xl text-center leading-[1.05]">
      More than <br />
      just trade learning
    </h2>

    <div class="grid gap-5 md:grid-cols-3">
      {cards.map((c) => (
        <article class="rounded-2xl bg-white p-6 space-y-4">
          <div class="h-32 rounded-xl bg-neutral-100 grid place-items-center text-2xl text-neutral-500">
            {c.chip}
          </div>
          <h3 class="text-xl font-bold">{c.title}</h3>
          <p class="text-sm text-neutral-600">{c.desc}</p>
          <a href="#" class="inline-flex items-center gap-2 text-sm font-medium pt-2 hover:text-[#2e9494]">
            Learn More <span aria-hidden>↗</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
