---
import Logo from "./Logo.astro";
import Button from "./Button.astro";

const nav = [
  { label: "Courses", href: "/courses" },
  { label: "How does it work?", href: "/how-it-works" },
  { label: "Student support", href: "/support" },
  { label: "Jobs", href: "/jobs" },
  { label: "Locations", href: "/locations" },
];
---

<header class="bg-neutral-0 border-b border-neutral-100">
  <div class="container-page flex items-center justify-between py-4">
    <Logo variant="dark" />

    <nav class="hidden lg:flex items-center gap-6 text-sm text-brand-primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class="hover:text-brand-accent-strong transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <Button href="/enquire" variant="accent" size="md">Enquire now</Button>
      <Button href="/login" variant="outline" size="md">Log in</Button>
    </div>
  </div>
</header>
