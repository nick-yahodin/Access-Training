---
const videos = [
  {
    img: "/images/comm-1.png",
    name: "Linda Goren",
    role: "Access Training tutor",
    quote: "I enjoy helping students develop real-world skills and prepare for successful careers in the industry.",
  },
  {
    img: "/images/comm-2.png",
    name: "Tom Pratchat",
    role: "Employer",
    quote: "A great source of well-prepared, job-ready candidates who are ready to start work with confidence.",
  },
  {
    img: "/images/comm-3.png",
    name: "Leo Escusei",
    role: "Student at Access Training",
    quote: "The tutors were supportive and the on-site training really prepared me for the job.",
  },
  {
    img: "/images/comm-4.png",
    name: "Ramir Ferneras",
    role: "Student at Access Training",
    quote: "Always supported, always learning, and real help with getting into work.",
  },
];
---

<section class="bg-[#ECEBE6] text-black py-20">
  <div class="container-page space-y-12">
    <div class="text-center space-y-4 max-w-3xl mx-auto">
      <h2 class="display text-5xl md:text-7xl lg:text-[96px] leading-[1.05]">
        Be a part of <br />
        <span class="text-[#ee7d5c]">our community</span>
      </h2>
      <p class="text-lg text-neutral-700">
        Get 24/7 expert guidance, live training, CV help, job opportunities, and
        up to 3 years of guidance.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {videos.map((v) => (
        <article class="space-y-3">
          <div class="relative aspect-[4/5] rounded-2xl overflow-hidden">
            <img src={v.img} alt={v.name} class="absolute inset-0 w-full h-full object-cover" />
            <button
              type="button"
              aria-label={`Play story from ${v.name}`}
              class="absolute inset-0 m-auto w-14 h-14 rounded-full bg-white/95 grid place-items-center text-black"
            >
              <svg viewBox="0 0 24 24" class="w-5 h-5 ml-1" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </button>
          </div>
          <div class="space-y-1 px-1">
            <p class="font-medium">{v.name}</p>
            <p class="text-xs text-neutral-500">{v.role}</p>
            <p class="text-sm text-neutral-700 pt-1">"{v.quote}"</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
