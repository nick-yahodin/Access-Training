---
const cards = [
  {
    title: "Partners",
    desc: "Priority access to roles from our network of UK trade hiring partners across plumbing, gas, and electrical.",
    img: "https://images.unsplash.com/photo-1530124566582-a618bc2615dc?auto=format&fit=crop&w=600&q=80",
    href: "/partners",
  },
  {
    title: "Get career support",
    desc: "Free CV reviews, interview prep, and recruiter intros — included with every Access Training course.",
    img: "https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=600&q=80",
    href: "/support",
  },
  {
    title: "Exclusive jobs",
    desc: "Exclusive job listings only available to Access Training graduates. Trades, on the move, every day.",
    img: "https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&w=600&q=80",
    href: "/jobs",
  },
];
---

<section class="bg-brand-cream pb-16">
  <div class="container-page space-y-10">
    <h2 class="display text-5xl md:text-6xl text-brand-primary text-center">
      More than
      <br />
      <span class="text-brand-accent-strong">just trade learning</span>
    </h2>

    <div class="grid gap-5 md:grid-cols-3">
      {cards.map((c) => (
        <article class="bg-neutral-0 rounded-2xl overflow-hidden flex flex-col">
          <div class="aspect-[5/3] overflow-hidden">
            <img src={c.img} alt={c.title} class="w-full h-full object-cover" />
          </div>
          <div class="p-6 space-y-3 flex-1">
            <h3 class="font-semibold text-brand-primary text-lg">{c.title}</h3>
            <p class="text-sm text-neutral-600">{c.desc}</p>
            <a
              href={c.href}
              class="inline-flex items-center gap-1 text-sm text-brand-accent-strong hover:underline pt-2"
            >
              Learn More <span aria-hidden>→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
