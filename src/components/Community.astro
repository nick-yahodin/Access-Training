---
const videos = [
  {
    name: "Jamie Foster",
    role: "Plumber",
    img: "https://images.unsplash.com/photo-1531546946076-31c2a9d0e2c8?auto=format&fit=crop&w=600&q=80",
  },
  {
    name: "Tom Andrews",
    role: "Gas engineer",
    img: "https://images.unsplash.com/photo-1502685104226-ee32379fefbe?auto=format&fit=crop&w=600&q=80",
  },
  {
    name: "Lisa Bennett",
    role: "Electrician",
    img: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=600&q=80",
  },
  {
    name: "Reece Patel",
    role: "Plumber",
    img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=600&q=80",
  },
];
---

<section class="bg-brand-cream section-pad">
  <div class="container-page space-y-10">
    <div class="text-center space-y-3 max-w-2xl mx-auto">
      <h2 class="display text-5xl md:text-6xl text-brand-primary">
        Be a part of
        <br />
        <span class="text-brand-warning">our community</span>
      </h2>
      <p class="text-neutral-600">
        Get 24/7 expert guidance, live training, CV help, job opportunities, and
        a 21-year community on your side.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {videos.map((v) => (
        <article class="relative aspect-[4/5] rounded-2xl overflow-hidden group">
          <img
            src={v.img}
            alt={v.name}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <button
            type="button"
            aria-label={`Play story from ${v.name}`}
            class="absolute inset-0 m-auto w-14 h-14 rounded-full bg-neutral-0/95 flex items-center justify-center text-brand-primary text-xl"
          >
            ▶
          </button>
          <div class="absolute bottom-0 left-0 right-0 p-4 text-neutral-0">
            <div class="font-semibold">{v.name}</div>
            <div class="text-xs text-neutral-200">{v.role}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
