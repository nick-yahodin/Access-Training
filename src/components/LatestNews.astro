---
const posts = [
  {
    title: "Training centres in Wales now locally, quality nationally",
    date: "April 12, 2026",
    read: "3 min read",
    img: "https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=600&q=80",
    href: "/blog/wales-centres",
  },
  {
    title: "Plumbing while you earn — feels the system really works",
    date: "April 4, 2026",
    read: "5 min read",
    img: "https://images.unsplash.com/photo-1607400201515-c2c41c07d307?auto=format&fit=crop&w=600&q=80",
    href: "/blog/earn-while-you-learn",
  },
  {
    title: "Train in the UK Midlands: career training folks",
    date: "March 30, 2026",
    read: "4 min read",
    img: "https://images.unsplash.com/photo-1581094288338-2314dddb7ece?auto=format&fit=crop&w=600&q=80",
    href: "/blog/midlands",
  },
  {
    title: "Start your trade career in Scotland with real opportunity",
    date: "March 22, 2026",
    read: "4 min read",
    img: "https://images.unsplash.com/photo-1581094799710-b3eb9b9a0eaf?auto=format&fit=crop&w=600&q=80",
    href: "/blog/scotland",
  },
];
---

<section class="bg-brand-primary text-neutral-0 section-pad">
  <div class="container-page space-y-10">
    <div class="text-center space-y-4">
      <h2 class="display text-5xl md:text-6xl">
        Latest <span class="text-brand-warning">news</span>
      </h2>
      <p class="max-w-2xl mx-auto text-neutral-200">
        Learn all about the training courses we provide and catch up on student
        stories from across the trade world.
      </p>
      <a
        href="/blog"
        class="inline-flex items-center justify-center px-6 py-3 rounded-full border border-neutral-200 text-sm hover:border-brand-accent hover:text-brand-accent transition-colors"
      >
        View All
      </a>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {posts.map((p) => (
        <article class="rounded-2xl overflow-hidden bg-brand-primary-700">
          <div class="aspect-[5/3] overflow-hidden">
            <img src={p.img} alt={p.title} class="w-full h-full object-cover" />
          </div>
          <div class="p-5 space-y-3">
            <div class="text-xs text-neutral-400 flex items-center gap-3">
              <span>{p.date}</span>
              <span>·</span>
              <span>{p.read}</span>
            </div>
            <a href={p.href} class="font-medium hover:text-brand-accent">
              {p.title}
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
